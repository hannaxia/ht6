# ── External credentials (fill these in; see README.md "Setup checklist") ──
STAY22_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=
MAPBOX_ACCESS_TOKEN=
MONGODB_URI=

# ── Auth0 (Regular Web Application; generate AUTH0_SECRET with openssl rand -hex 32) ──
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
APP_BASE_URL=
AUTH0_SECRET==
APP_BASE_URL=

# ── Backend ──
PORT=4000
LOG_LEVEL=info
FRONTEND_ORIGIN=http://localhost:3000

# ── Web app (NEXT_PUBLIC_* vars are exposed to the browser) ──
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_DEBUG=false